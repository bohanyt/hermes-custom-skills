# Hermes Multi-Terminal API Key Config
# Format: # instance_name, then API key on next line
# Lines starting with # (after first char) are instance names
# All other non-empty lines are API keys

# terminal-1
sk-or-v1-REPLACE_WITH_YOUR_FIRST_KEY

# terminal-2
sk-or-v1-REPLACE_WITH_YOUR_SECOND_KEY

# terminal-3
sk-or-v1-REPLACE_WITH_YOUR_THIRD_KEY
